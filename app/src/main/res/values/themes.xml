<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.DailyDo" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_variant</item>
        <item name="colorOnPrimaryContainer">@color/on_primary</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_variant</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary</item>
        
        <!-- Status colors -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        
        <!-- Surface and background colors -->
        <item name="android:colorBackground">@color/black</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <!-- Typography -->
        <item name="textAppearanceHeadline1">@style/TextAppearance.App.HeadlineLarge</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.App.HeadlineMedium</item>
        <item name="textAppearanceHeadline3">@style/TextAppearance.App.HeadlineSmall</item>
        <item name="textAppearanceSubtitle1">@style/TextAppearance.App.TitleMedium</item>
        <item name="textAppearanceSubtitle2">@style/TextAppearance.App.TitleSmall</item>
        <item name="textAppearanceBody1">@style/TextAppearance.App.BodyLarge</item>
        <item name="textAppearanceBody2">@style/TextAppearance.App.BodyMedium</item>
        <item name="textAppearanceButton">@style/TextAppearance.App.LabelLarge</item>
        <item name="textAppearanceCaption">@style/TextAppearance.App.LabelMedium</item>
        <item name="textAppearanceOverline">@style/TextAppearance.App.LabelSmall</item>
        
        <!-- Shape -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.DailyDo.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.DailyDo.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.DailyDo.Large</item>
    </style>

    <style name="Theme.DailyDo" parent="Base.Theme.DailyDo" />

    <!-- Custom DatePickerDialog theme: swap header/body colors -->
    <style name="ThemeOverlay.DailyDo.DatePicker" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <!-- Header text color (Title/Month) -->
        <item name="colorPrimary">@color/logo_purple_light</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <!-- Body calendar color -->
        <item name="colorSurface">@color/logo_purple_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <!-- Shape Appearances -->
    <style name="ShapeAppearance.DailyDo.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    
    <style name="ShapeAppearance.DailyDo.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    
    <style name="ShapeAppearance.DailyDo.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
</resources>