<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Section -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:elevation="0dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:paddingStart="@dimen/spacing_large"
                android:paddingEnd="@dimen/spacing_large"
                app:title="Hydration Status"
                app:titleTextAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                app:titleTextColor="@color/text_primary" />

        </com.google.android.material.appbar.AppBarLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_large">

            <!-- Main Hydration Tracker Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_large"
                app:cardCornerRadius="28dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/logo_purple_bg"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_large"
                    android:gravity="center">

                    <!-- Top-right Set Goal button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_set_goal"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_gravity="end"
                        android:text="SET GOAL"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_progress"
                        app:iconSize="18dp"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp"
                        app:backgroundTint="@color/go_lanka_orange"
                        app:strokeWidth="0dp" />

                    <!-- Circular Progress Section -->
                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:layout_marginBottom="@dimen/spacing_large">

                        <!-- Circular Progress Indicator -->
                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/circular_progress_hydration"
                            android:layout_width="200dp"
                            android:layout_height="200dp"
                            android:progress="45"
                            android:max="100"
                            app:indicatorColor="@color/logo_orange_stroke"
                            app:trackColor="@color/dark_gray"
                            app:trackThickness="12dp"
                            app:indicatorSize="200dp"
                            tools:progress="45" />

                        <!-- Water Droplet Icon in Center -->
                        <ImageView
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_centerInParent="true"
                            android:layout_marginBottom="20dp"
                            android:src="@drawable/ic_water_drop"
                            app:tint="@color/accent_blue" />

                    </RelativeLayout>

                    <!-- Daily Goal and Current Intake Labels -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_large"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- Daily Goal -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DAILY GOAL:"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/tv_daily_goal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_extra_small"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="2000 ml" />

                        </LinearLayout>

                        <!-- Current Intake -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CURRENT INTAKE:"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/tv_current_intake"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_extra_small"
                                android:textColor="@color/logo_purple_light"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="900 ml" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Progress Percentage -->
                    <TextView
                        android:id="@+id/tv_progress_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_large"
                        android:textColor="@color/success_green"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="45% of Goal Reached" />

                    <!-- Main Action Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_add_water"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="@dimen/spacing_medium"
                        android:text="ADD WATER"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:letterSpacing="0.1"
                        app:backgroundTint="@color/logo_purple_light"
                        app:cornerRadius="16dp"
                        app:icon="@drawable/ic_add"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp" />

                    <!-- Secondary Action Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_set_reminder"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginEnd="@dimen/spacing_small"
                            android:text="SET REMINDER"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textAllCaps="false"
                            android:letterSpacing="0.1"
                            app:cornerRadius="12dp"
                            app:icon="@drawable/ic_alarm"
                            app:iconGravity="textStart"
                            app:iconPadding="4dp"
                            app:backgroundTint="@color/go_lanka_orange"
                            app:strokeWidth="0dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Recent Activity Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_large">

                    <!-- Header with View All Button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Recent Activity"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />


                    </LinearLayout>

                    <!-- Activity List -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_hydration_history"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_medium"
                        android:nestedScrollingEnabled="false"
                        tools:itemCount="3"
                        tools:listitem="@layout/item_hydration_history" />

                    <!-- Empty State -->
                    <LinearLayout
                        android:id="@+id/layout_empty_hydration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_medium"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_large"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_water_drop"
                            app:tint="@color/text_hint" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_medium"
                            android:text="No water intake recorded today"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_extra_small"
                            android:gravity="center"
                            android:text="Tap 'Add Water' to start tracking"
                            android:textColor="@color/text_tertiary"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>



        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>